NODE_ENV=development
PORT=5000

# ── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=jyotish_stack_ai_db

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=no-reply@jyotishstack.com

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── CORS Allowed Origins ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://jyotishstack.com,https://jyotishstack.in,https://jyotishstackai.com,https://jyotishstackai.in

# ── Deterministic Q&A (no-LLM) — TEMPORARY migration flags ───────────────────
# QA_DETERMINISTIC_ANSWER gates the predefined-question answer endpoint during
#   the pilot rollout; it is removed (answers become unconditional) once the
#   pilot is accepted.
# QA_DB_CATALOGUE switches the LEGACY /kundli/question-bank endpoint to the DB
#   catalogue; it is removed in Stage 3 when question-bank.js is deleted.
QA_DETERMINISTIC_ANSWER=true
QA_DB_CATALOGUE=false
