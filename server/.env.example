NODE_ENV=development
PORT=5000

# ── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=jyotish_stack_ai_db

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=no-reply@jyotishstack.com

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── CORS Allowed Origins ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://jyotishstack.com,https://jyotishstack.in,https://jyotishstackai.com,https://jyotishstackai.in

# ── Ask-a-Question AI (local Ollama / Qwen3) ─────────────────────────────────
# Local LLM that writes the natural-language "Final Answer" for Kundli Q&A.
# Defaults work if Ollama runs on the same host with qwen3:4b pulled.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_MS=60000
