# Jyotish Stack AI - Production Environment Template
# Copy to server/.env and fill in real values on your server.
# NEVER commit the actual .env to git.

NODE_ENV=production

# Server
PORT=5000
APP_URL=https://jyotishstack.com
ALLOWED_ORIGINS=https://jyotishstack.com,https://www.jyotishstack.com
JWT_SECRET=replace_with_long_random_hex_from_openssl_rand_hex_64
JWT_REFRESH_SECRET=replace_with_second_long_random_hex_from_openssl_rand_hex_64
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Local-only free Python question understanding service
QUESTION_SERVICE_ENABLED=true
QUESTION_SERVICE_URL=http://127.0.0.1:5100
QUESTION_SERVICE_TIMEOUT_MS=1800
# Optional shared secret. Leave empty when the service remains bound to 127.0.0.1.
QUESTION_SERVICE_TOKEN=

# MySQL - keep MySQL bound to 127.0.0.1 on the VPS.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=jyotish_app
DB_PASSWORD=replace_with_strong_password
DB_NAME=jyotish_stack_ai_db
DB_SSL=false

# Razorpay (can also be set via Admin > Settings > Payments)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret

# EMAIL - self-hosted SMTP on this VPS for jyotishstack.com
# Run first:
#   sudo bash scripts/setup-self-hosted-smtp.sh jyotishstack.com
#
# DNS must include:
#   A     mail      <VPS_PUBLIC_IP>
#   MX    @   10   mail.jyotishstack.com
#   TXT   @        "v=spf1 mx -all"
#   TXT   _dmarc   "v=DMARC1; p=quarantine; rua=mailto:account@jyotishstack.com; adkim=s; aspf=s"
#   TXT   mail._domainkey from /etc/opendkim/keys/jyotishstack.com/mail.txt
# Also set reverse DNS/PTR for the VPS IP to mail.jyotishstack.com.
#
SMTP_HOST=mail.jyotishstack.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_TLS_SERVERNAME=mail.jyotishstack.com

# Per-mailbox credentials. Passwords are generated by the setup script in:
#   /root/jyotish-mailbox-passwords.txt
MAIL_SALES_USER=sales@jyotishstack.com
MAIL_SALES_PASS=replace_with_sales_mailbox_password
MAIL_SALES_FROM=Jyotish Stack Sales <sales@jyotishstack.com>

MAIL_TEAM_USER=team@jyotishstack.com
MAIL_TEAM_PASS=replace_with_team_mailbox_password
MAIL_TEAM_FROM=Jyotish Stack Support <team@jyotishstack.com>

MAIL_ACCOUNT_USER=account@jyotishstack.com
MAIL_ACCOUNT_PASS=replace_with_account_mailbox_password
MAIL_ACCOUNT_FROM=Jyotish Stack <account@jyotishstack.com>

# Fallback single account (used only if the MAIL_*_USER vars above are unset):
SMTP_USER=account@jyotishstack.com
SMTP_PASS=replace_with_account_mailbox_password
SMTP_FROM=Jyotish Stack <account@jyotishstack.com>
