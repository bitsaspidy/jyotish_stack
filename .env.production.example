# Jyotish Stack AI - Production Environment Template
# Copy to server/.env and fill in real values on your server.
# NEVER commit the actual .env to git.

NODE_ENV=production

# Server
PORT=5000
APP_URL=https://jyotishstack.com
ALLOWED_ORIGINS=https://jyotishstack.com,https://www.jyotishstack.com
JWT_SECRET=replace_with_long_random_hex_from_openssl_rand_hex_64
JWT_REFRESH_SECRET=replace_with_second_long_random_hex_from_openssl_rand_hex_64
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# MySQL - keep MySQL bound to 127.0.0.1 on the VPS.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=jyotish_app
DB_PASSWORD=replace_with_strong_password
DB_NAME=jyotish_stack_ai_db
DB_SSL=false

# Razorpay (can also be set via Admin > Settings > Payments)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret

# AI / Anthropic
# Required for AI Personalised Reading feature (KundliDetail > AI Reading tab)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL — Domain mailboxes (RECOMMENDED for jyotishstack.com)
# Three real mailboxes, each used for a different purpose:
#   sales@   -> sales enquiries
#   team@    -> support / general
#   account@ -> account & billing, plus all auth emails (verify, reset, receipts)
# Create them in Hostinger hPanel (Emails) or Zoho Mail, then add MX/SPF/DKIM/DMARC
# DNS records (see the setup steps). Use the FULL email address as the SMTP username.
#
# Shared mail host (same for all three mailboxes):
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
#
# Per-mailbox credentials (username = full email address):
MAIL_SALES_USER=sales@jyotishstack.com
MAIL_SALES_PASS=replace_with_sales_mailbox_password
MAIL_SALES_FROM=Jyotish Stack Sales <sales@jyotishstack.com>

MAIL_TEAM_USER=team@jyotishstack.com
MAIL_TEAM_PASS=replace_with_team_mailbox_password
MAIL_TEAM_FROM=Jyotish Stack Support <team@jyotishstack.com>

MAIL_ACCOUNT_USER=account@jyotishstack.com
MAIL_ACCOUNT_PASS=replace_with_account_mailbox_password
MAIL_ACCOUNT_FROM=Jyotish Stack <account@jyotishstack.com>
#
# Fallback single account (used only if the MAIL_*_USER vars above are unset):
SMTP_USER=account@jyotishstack.com
SMTP_PASS=replace_with_account_mailbox_password
SMTP_FROM=Jyotish Stack <account@jyotishstack.com>
# ─────────────────────────────────────────────────────────────────────────────

# SMTP - Alternative Option A: Gmail App Password
# 1. Enable 2-Factor Authentication on Gmail
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
# 4. Use your Gmail address as SMTP_USER and the 16-char app password as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
SMTP_FROM=Jyotish Stack AI <your.email@gmail.com>

# SMTP - Option B: Brevo
# Sign up at https://brevo.com, go to SMTP & API, copy credentials below:
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_brevo_login@example.com
# SMTP_PASS=xsmtpsib-xxxxxxxxxxxxxxxxxxxxxxxx
# SMTP_FROM=Jyotish Stack AI <noreply@yourdomain.com>
# SMTP - Option C: SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMTP_FROM=Jyotish Stack AI <noreply@yourdomain.com>
